        with open(report_file, 'w') as f:
            f.write("="*80 + "\n")
            f.write("SEA SURFACE TEMPERATURE STATISTICAL ANALYSIS REPORT\n")
            f.write("="*80 + "\n\n")
            
            f.write(f"Observed data file: {self.obs_file}\n")
            f.write(f"Model data file: {self.model_file}\n")
            f.write(f"Observed variable: {self.obs_varname}\n")
            f.write(f"Model variable: {self.model_varname}\n\n")
            
            f.write("="*80 + "\n")
            f.write("GLOBAL STATISTICS\n")
            f.write("="*80 + "\n")
            f.write(f"Number of samples:              {self.stats['n_samples']:,}\n")
            f.write(f"Bias (Model - Obs):             {self.stats['bias']:10.4f} °C\n")
            f.write(f"Root Mean Square Error (RMSE):  {self.stats['rmse']:10.4f} °C\n")
            f.write(f"Mean Absolute Error (MAE):      {self.stats['mae']:10.4f} °C\n")
            f.write(f"Spatial Correlation:            {self.stats['correlation']:10.4f}\n")
            f.write(f"Temporal Correlation:           {self.stats['temporal_correlation']:10.4f}\n\n")
            
            f.write("="*80 + "\n")
            f.write("OBSERVED SST STATISTICS\n")
            f.write("="*80 + "\n")
            f.write(f"Mean:                           {self.stats['obs_mean']:10.4f} °C\n")
            f.write(f"Standard Deviation:             {self.stats['obs_std']:10.4f} °C\n")
            f.write(f"Minimum:                        {self.stats['obs_min']:10.4f} °C\n")
            f.write(f"Maximum:                        {self.stats['obs_max']:10.4f} °C\n\n")
            
            f.write("Quantiles:\n")
            for q, val in self.stats['obs_quantiles'].items():
                f.write(f"  {q:5.2%}:                         {val:10.4f} °C\n")
            f.write("\n")
            
            f.write("="*80 + "\n")
            f.write("MODELED SST STATISTICS\n")
            f.write("="*80 + "\n")
            f.write(f"Mean:                           {self.stats['model_mean']:10.4f} °C\n")
            f.write(f"Standard Deviation:             {self.stats['model_std']:10.4f} °C\n")
            f.write(f"Minimum:                        {self.stats['model_min']:10.4f} °C\n")
            f.write(f"Maximum:                        {self.stats['model_max']:10.4f} °C\n\n")
            
            f.write("Quantiles:\n")
            for q, val in self.stats['model_quantiles'].items():
                f.write(f"  {q:5.2%}:                         {val:10.4f} °C\n")
            f.write("\n")
            
            f.write("="*80 + "\n")
            f.write("MONTHLY STATISTICS\n")
            f.write("="*80 + "\n")
            month_names = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                          'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
            f.write(f"{'Month':<10} {'Bias (°C)':>12} {'RMSE (°C)':>12}\n")
            f.write("-" * 40 + "\n")
            for i, month in enumerate(month_names, 1):
                f.write(f"{month:<10} {self.stats['monthly_bias'][i]:12.4f} "
                       f"{self.stats['monthly_rmse'][i]:12.4f}\n")
            
        print(f"\nStatistics report saved to: {report_file}")
        
    def save_netcdf_outputs(self):
        """Save regridded observations and computed statistics as NetCDF."""
        print("\nSaving NetCDF outputs...")
        
        # Save regridded observations
        regridded_file = self.output_dir / 'obs_regridded.nc'
        self.obs_regridded.to_netcdf(regridded_file)
        print(f"Regridded observations saved to: {regridded_file}")
        
        # Save spatial statistics
        stats_ds = xr.Dataset({
            'bias': self.spatial_bias,
            'rmse': self.spatial_rmse,
            'correlation': self.spatial_corr
        })
        stats_file = self.output_dir / 'spatial_statistics.nc'
        stats_ds.to_netcdf(stats_file)
        print(f"Spatial statistics saved to: {stats_file}")


def main():
    """Main execution function with example usage."""
    import argparse
    
    parser = argparse.ArgumentParser(
        description='Comprehensive statistical analysis of observed and modeled SST data')
    parser.add_argument('obs_file', type=str, help='Path to observed SST NetCDF file')
    parser.add_argument('model_file', type=str, help='Path to modeled SST NetCDF file')
    parser.add_argument('--obs-var', type=str, default=None,
                       help='Observed SST variable name (auto-detected if not provided)')
    parser.add_argument('--model-var', type=str, default=None,
                       help='Model SST variable name (auto-detected if not provided)')
    parser.add_argument('--output-dir', type=str, default='./sst_analysis_output',
                       help='Output directory for results')
    parser.add_argument('--regrid-method', type=str, default='nearest',
                       choices=['nearest', 'bilinear'],
                       help='Regridding method')
    
    args = parser.parse_args()
    
    # Create analyzer
    analyzer = SSTAnalyzer(args.obs_file, args.model_file, args.output_dir)
    
    # Load data
    analyzer.load_data(args.obs_var, args.model_var)
    
    # Regrid observations to model grid
    analyzer.regrid_observations(method=args.regrid_method)
    
    # Compute statistics
    analyzer.compute_statistics()
    
    # Create visualizations
    analyzer.create_visualizations()
    
    # Save reports
    analyzer.save_statistics_report()
    analyzer.save_netcdf_outputs()
    
    print("\n" + "="*60)
    print("Analysis complete!")
    print(f"All outputs saved to: {analyzer.output_dir}")
    print("="*60)


if __name__ == '__main__':
    main()
