# Ignore everything generated by layout.py / validation scripts.
# Manually-authored content (*.md, *.yaml, *.sh) is tracked normally.

# Generated validation output (AnalysesLayout — new layout)
areas/*/validations/*/plots/
areas/*/validations/*/tables/

# Generated files dropped directly in validations/<EXP>/ (old layout)
areas/*/validations/*/*.png
areas/*/validations/*/*.csv
areas/*/validations/*/*.txt

# Old-layout scenarios under areas/ (now top-level scenarios/)
areas/*/scenarios/
areas/*/scenarios.keep/

# Generated bias-correction diagnostics (BCDiagnosticsLayout)
scenarios/plots/
scenarios/tables/

# Simulation registry — generated by simulation_list_db.py
simulation_list.db
staging/
